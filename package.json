{
  "type": "module",
  "name": "emdash-alchemy-template",
  "private": true,
  "scripts": {
    "build": "astro build",
    "deploy:staging": "alchemy deploy --stage staging",
    "deploy:prod": "alchemy deploy --stage prod",

    "typecheck": "astro check && wrangler types && tsc -b"
  },
  "dependencies": {
    "astro": "^6.1.7",
    "emdash": "^0.5.0",
    "@astrojs/react": "^5.0.3",
    "@astrojs/cloudflare": "^13.1.10",
    "@types/bun": "^1.3.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "@emdash-cms/cloudflare": "^0.5.0"
  },
  "devDependencies": {
    "@astrojs/compiler-rs": "^0.1.7",
    "@cloudflare/vite-plugin": "^1.32.3",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^20",
    "@types/react": "^19.2.3",
    "@types/react-dom": "^19.2.3",
    "alchemy": "^0.90.1",
    "miniflare": "^4.20250617.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.8.3",
    "@astrojs/check": "^0.9.8",
